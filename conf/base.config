def runStamp = java.time.ZonedDateTime
  .now(java.time.ZoneOffset.UTC)
  .format(java.time.format.DateTimeFormatter.ofPattern("yyyy-MM-dd_HH-mm-ss'Z'"))
def taxonomyDbWasSupplied = params.taxonomy_db ? true : false
def taxonomyCacheDir = params.taxonomy_cache_dir ?: "${projectDir}/runtime/cache/taxonomy"
def taxonomyAutoBuild = params.containsKey('taxonomy_auto_build') ? params.taxonomy_auto_build : true
def dockerhubNamespace = params.dockerhub_namespace ?: 'rafaelmdc'
def containerTag = params.container_tag ?: '0.1.0'

params {
  dockerhub_namespace = dockerhubNamespace
  container_tag = containerTag
  taxonomy_db_supplied = taxonomyDbWasSupplied
  accessions_file = null
  taxonomy_cache_dir = taxonomyCacheDir
  taxonomy_db = params.taxonomy_db ?: "${taxonomyCacheDir}/ncbi_taxonomy.sqlite"
  taxonomy_auto_build = taxonomyAutoBuild
  dry_run_inputs = false
  run_id = params.run_id ?: "pipeline_${runStamp}"
  run_root = params.run_root ?: "${projectDir}/runs/${params.run_id}"
  output_dir = params.output_dir ?: "${params.run_root}/publish"
  work_dir = params.work_dir ?: null
  acquisition_publish_mode = 'raw'
  repeat_residues = 'Q'
  run_pure = true
  pure_min_repeat_count = 6
  run_threshold = true
  threshold_window_size = 8
  threshold_min_target_count = 6
  run_seed_extend = false
  seed_extend_seed_window_size = 8
  seed_extend_seed_min_target_count = 6
  seed_extend_extend_window_size = 12
  seed_extend_extend_min_target_count = 8
  seed_extend_min_total_length = 10
  batch_size = 10
  python_bin = "env PYTHONPATH=${projectDir}/src python3"
  datasets_bin = 'datasets'
  taxon_weaver_bin = 'taxon-weaver'
  acquisition_container = params.acquisition_container ?: "${dockerhubNamespace}/homorepeat-acquisition:${containerTag}"
  detection_container = params.detection_container ?: "${dockerhubNamespace}/homorepeat-detection:${containerTag}"
  dev_acquisition_container = params.dev_acquisition_container ?: 'homorepeat-acquisition:dev'
  dev_detection_container = params.dev_detection_container ?: 'homorepeat-detection:dev'
  ncbi_api_key = null
  ncbi_cache_dir = null
  ncbi_dehydrated = false
  ncbi_rehydrate = false
  ncbi_rehydrate_workers = null
}

outputDir = params.output_dir

workflow.output.mode = 'copy'

workDir = params.work_dir ?: "${params.run_root}/internal/nextflow/work"

timeline {
  enabled = true
  file = "${params.run_root}/internal/nextflow/timeline.html"
  overwrite = true
}

report {
  enabled = true
  file = "${params.run_root}/internal/nextflow/report.html"
  overwrite = true
}

trace {
  enabled = true
  file = "${params.run_root}/internal/nextflow/trace.txt"
  overwrite = true
}

dag {
  enabled = true
  file = "${params.run_root}/internal/nextflow/dag.html"
  overwrite = true
}

process {
  errorStrategy = 'finish'
  maxRetries = 0

  withLabel: planning {
    cpus = 1
    memory = '1 GB'
    maxForks = 1
  }

  withLabel: acquisition_download {
    cpus = 1
    memory = '2 GB'
    maxForks = 2
  }

  withLabel: taxonomy_build {
    cpus = 1
    memory = '4 GB'
    maxForks = 1
  }

  withLabel: acquisition_normalize {
    cpus = 1
    memory = '6 GB'
    maxForks = 2
  }

  withLabel: acquisition_translate {
    cpus = 1
    memory = '4 GB'
    maxForks = 2
  }

  withLabel: acquisition_merge {
    cpus = 1
    memory = '2 GB'
    maxForks = 1
  }

  withLabel: detection {
    cpus = 1
    memory = '2 GB'
    maxForks = 4
  }

  withLabel: database {
    cpus = 1
    memory = '2 GB'
    maxForks = 1
  }

  withLabel: reporting {
    cpus = 1
    memory = '1 GB'
    maxForks = 1
  }
}
