params {
  accessions_file = null
  taxonomy_db = null
  run_root = 'runs/dev_run'
  output_dir = 'runs/dev_run/publish'
  repeat_residues = 'Q'
  run_pure = true
  pure_min_repeat_count = 6
  run_threshold = true
  threshold_window_size = 8
  threshold_min_target_count = 6
  run_seed_extend_polyq = false
  seed_extend_seed_window_size = 8
  seed_extend_seed_min_q_count = 6
  seed_extend_extend_window_size = 12
  seed_extend_extend_min_q_count = 8
  seed_extend_min_total_length = 10
  batch_size = 100
  python_bin = 'python3'
  datasets_bin = 'datasets'
  taxon_weaver_bin = 'taxon-weaver'
  acquisition_container = 'homorepeat-acquisition:dev'
  detection_container = 'homorepeat-detection:dev'
  ncbi_api_key = null
  ncbi_cache_dir = null
  ncbi_dehydrated = false
  ncbi_rehydrate = false
  ncbi_rehydrate_workers = null
}

workDir = "${params.run_root}/internal/nextflow/work"

process {
  errorStrategy = 'terminate'
  maxRetries = 0

  withLabel: planning {
    cpus = 1
  }

  withLabel: acquisition_download {
    cpus = 1
  }

  withLabel: acquisition_normalize {
    cpus = 1
  }

  withLabel: acquisition_merge {
    cpus = 1
  }

  withLabel: detection {
    cpus = 1
  }

  withLabel: database {
    cpus = 1
  }

  withLabel: reporting {
    cpus = 1
  }
}
